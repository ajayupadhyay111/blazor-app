@inject DraftStore Store

<div class="gov-note">
    <strong>Are you Registered on this portal (For Fresh Applicants)?</strong><br />
    If you have already submitted the Application Form through the On-Line process and have a valid
    Registration Code with your Registered Mobile No., select <em>Yes</em>; otherwise select <em>No</em>.
    A fresh On-Line Application Form must be submitted for each Course / Seat Enhancement request.
</div>

<div class="field">
    <div class="radioset">
        <label><input type="radio" name="isreg" value="0"
               checked="@(Store.Current.Registration.IsRegistered == "0")"
               @onchange="@(() => Set("0"))" /> No (Fresh Applicant)</label>
        <label><input type="radio" name="isreg" value="1"
               checked="@(Store.Current.Registration.IsRegistered == "1")"
               @onchange="@(() => Set("1"))" /> Yes (Already Registered)</label>
    </div>
</div>

@if (Store.Current.Registration.IsRegistered == "1")
{
    <div class="gov-card" style="margin-top:6px;">
        <div class="gov-card-head"><span class="num">★</span> View Your Submitted Application</div>
        <div class="gov-card-body">
            <p class="hint">Enter the Registration Code and Registered Mobile No. you received at submission.</p>
            <div class="row2">
                <div class="field">
                    <label>Registration Code <span class="req">*</span></label>
                    <input type="text" placeholder="e.g. UP-AFF-2026-0001" @bind="_code" />
                </div>
                <div class="field">
                    <label>Registered Mobile No. <span class="req">*</span></label>
                    <input type="text" maxlength="10" placeholder="10-digit mobile" @bind="_mobile" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_lookupError))
            {
                <div class="gov-errbox">@_lookupError</div>
            }

            <button class="btn-gov" @onclick="Lookup" disabled="@_searching">
                @if (_searching) { <span class="inline-spin"></span><text>Searching…</text> }
                else { <text>View My Application</text> }
            </button>

            <div class="gov-note" style="margin-top:14px;">
                Note: Without a central server, this lookup finds applications submitted on
                <strong>this browser/device</strong>. (Cross-device lookup needs the backend — Phase 2.)
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnChanged { get; set; }

    private string _code = "";
    private string _mobile = "";
    private string? _lookupError;
    private bool _searching;

    private async Task Set(string v)
    {
        Store.Current.Registration.IsRegistered = v;
        _lookupError = null;
        await Store.SaveAsync();
        await OnChanged.InvokeAsync();
    }

    private async Task Lookup()
    {
        _lookupError = null;
        if (string.IsNullOrWhiteSpace(_code) || string.IsNullOrWhiteSpace(_mobile))
        {
            _lookupError = "Please enter both Registration Code and Registered Mobile No.";
            return;
        }
        _searching = true;
        StateHasChanged();

        var found = await Store.LoadSubmittedAsync(_code, _mobile);
        _searching = false;

        if (found)
        {
            // Status is "submitted" now → the host renders the read-only application view.
            await OnChanged.InvokeAsync();
        }
        else
        {
            _lookupError = "No submitted application found with this Registration Code and Mobile No. on this device.";
        }
    }
}
