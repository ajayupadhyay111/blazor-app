@inject DraftStore Store

<p class="hint">Upload related photographs &amp; documents. Photos as zip (Front, Back &amp; Side View), Affidavit as pdf.
   Per-file size limits keep the whole application within the browser's local storage.</p>

<FileUpload @key="@("att1")" Label="Attachment-1: Teaching Block Photograph (Front, Back & Side View)" Accept=".zip" Required="true"
            MaxBytes="800 * 1024" Value="At.TeachingBlockPhoto" ValueChanged="@(v => Set(f => At.TeachingBlockPhoto = f, v))" />

<FileUpload @key="@("att2")" Label="Attachment-2: Hostel Block Photograph (Front, Back & Side View)" Accept=".zip"
            MaxBytes="500 * 1024" Value="At.HostelBlockPhoto" ValueChanged="@(v => Set(f => At.HostelBlockPhoto = f, v))" />

<FileUpload @key="@("att3")" Label="Attachment-3: Hospital Photograph (Front, Back & Side View)" Accept=".zip"
            MaxBytes="500 * 1024" Value="At.HospitalPhoto" ValueChanged="@(v => Set(f => At.HospitalPhoto = f, v))" />

<FileUpload @key="@("att4")" Label="Attachment-4: Hospital Staff Details (Doctors / Nurses / Allied Healthcare)" Accept=".zip" Required="true"
            MaxBytes="500 * 1024" Value="At.StaffDetails" ValueChanged="@(v => Set(f => At.StaffDetails = f, v))" />

<FileUpload @key="@("att5")" Label="Attachment-5: Affidavit on stamp paper attested by a Notary" Accept=".pdf" Required="true"
            MaxBytes="400 * 1024" Value="At.Affidavit" ValueChanged="@(v => Set(f => At.Affidavit = f, v))" />

@code {
    [Parameter] public EventCallback OnChanged { get; set; }
    private Attachments At => Store.Current.Attachments;

    private async Task Set(Action<UploadedFile?> assign, UploadedFile? value)
    {
        assign(value);
        await OnChanged.InvokeAsync(); // FileUpload already persisted to localStorage
    }
}
