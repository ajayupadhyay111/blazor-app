@inherits LayoutComponentBase

<div class="gov-topstrip"></div>
<header class="gov-header">
    <img src="logo.png" alt="Uttar Pradesh State Medical Faculty" class="gov-logo" />
    <div class="gov-header-text">
        <div class="portal">Online Affiliation Portal</div>
        <div class="sub">New College Opening / Seat Enhancement Application</div>
    </div>
</header>

<main>
